# 請複製此檔案為 .env.local 並填入對應的 API Key
# Copy this file to .env.local and fill in your API keys

# ── 必填 ─────────────────────────────────────────────
# Gemini AI (所有模組皆需要)
# Get your free key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── 模組 05 · 景觀地理分析 AI ──────────────────────────
# Cesium Ion Token (3D 地球儀 / 衛星底圖)
# 免費申請: https://ion.cesium.com/tokens
VITE_CESIUM_ION_TOKEN=your_cesium_ion_token_here

# 中央氣象署 (CWA) Open Data API — 即時氣象資料
# 免費申請: https://opendata.cwa.gov.tw/userLogin
VITE_CWA_API_KEY=your_cwa_api_key_here

# 環境部 (EPA) AQI 空氣品質 API — 即時 PM2.5 / AQI
# 免費申請: https://data.moenv.gov.tw/
VITE_EPA_API_KEY=your_epa_api_key_here

# ── 免費 / 不需 Key ──────────────────────────────────
# PVGIS (EU Solar) — 自動使用，不需 Key
# Open-Elevation   — 自動使用，不需 Key
# 國土測繪 NLSC WFS  — 需透過 Vite Dev Proxy (/nlsc-wfs) 存取
